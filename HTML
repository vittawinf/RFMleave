    function filterDashboardResidents() {
      const query = document.getElementById('mentorSearchResident').value.trim().toLowerCase();
      if (!loadedMentorDashboardData) return;
      
      const filtered = loadedMentorDashboardData.filter(res => {
        return res.name.toLowerCase().includes(query) || 
               res.id.toLowerCase().includes(query) || 
               String(res.year).includes(query) ||
               (res.mentorName && res.mentorName.toLowerCase().includes(query));
      });
      
      renderMentorDashboardList(filtered);
    }

