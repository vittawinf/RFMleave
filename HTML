<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบลาแพทย์ประจำบ้าน Family Medicine</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts: Inter & Sarabun -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!-- FontAwesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Sarabun', 'Inter', 'sans-serif'],
          },
          colors: {
            primary: {
              50: '#f0fdfa',
              100: '#ccfbf1',
              500: '#14b8a6',
              600: '#0d9488',
              700: '#0f766e',
              800: '#115e59',
            },
          }
        }
      }
    }
  </script>
  
  <style>
    body {
      background-color: #f8fafc;
    }
    .fade-in {
      animation: fadeIn 0.3s ease-out;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: #f1f5f9;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 3px;
    }
    
    @media print {
      body > *:not(#printContainer) {
        display: none !important;
      }
      #printContainer {
        display: block !important;
        background: white !important;
        color: black !important;
        width: 100% !important;
        height: auto !important;
      }
    }
  </style>
</head>
<body class="min-h-screen text-slate-800 flex flex-col font-sans">

  <!-- Header -->
  <header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <div class="flex items-center space-x-3">
          <div class="bg-primary-600 text-white p-2.5 rounded-xl shadow-md shadow-primary-600/20">
            <i class="fa-solid fa-notes-medical text-xl"></i>
          </div>
          <div>
            <h1 class="text-lg font-bold text-slate-900 leading-tight">ระบบลาแพทย์ประจำบ้าน</h1>
            <p class="text-xs text-slate-500 font-medium">Family Medicine Residency Leave System</p>
          </div>
        </div>
        
        <!-- User Badge & Logout -->
        <div id="userBadge" class="hidden flex items-center space-x-4">
          <div class="text-right hidden sm:block">
            <div id="badgeUserName" class="text-sm font-semibold text-slate-800">-</div>
            <div id="badgeUserRole" class="text-xs text-primary-600 font-medium">-</div>
          </div>
          <button onclick="logout()" class="flex items-center space-x-2 px-3.5 py-2 text-sm font-medium text-rose-600 hover:bg-rose-50 rounded-lg transition-colors border border-transparent hover:border-rose-100">
            <i class="fa-solid fa-arrow-right-from-bracket"></i>
            <span class="hidden sm:inline">ออกจากระบบ</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
    
    <!-- Toast Notification Container -->
    <div id="toastContainer" class="fixed top-20 right-4 z-50 flex flex-col space-y-2 pointer-events-none"></div>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center hidden">
      <div class="bg-white px-8 py-6 rounded-2xl shadow-xl flex flex-col items-center space-y-4 max-w-xs text-center border border-slate-100">
        <div class="relative w-12 h-12">
          <div class="absolute inset-0 rounded-full border-4 border-slate-100"></div>
          <div class="absolute inset-0 rounded-full border-4 border-t-primary-600 border-r-transparent border-b-transparent border-l-transparent animate-spin"></div>
        </div>
        <p id="loadingText" class="text-sm font-semibold text-slate-700">กำลังประมวลผล...</p>
      </div>
    </div>

    <!-- ================= PAGE 1: LOGIN ================= -->
    <section id="loginPage" class="fade-in max-w-md mx-auto my-12 hidden">
      <div class="bg-white rounded-3xl shadow-xl border border-slate-100 overflow-hidden">
        <div class="p-8 bg-gradient-to-br from-primary-700 to-primary-800 text-white text-center relative overflow-hidden">
          <div class="absolute -right-10 -bottom-10 opacity-10 text-8xl">
            <i class="fa-solid fa-stethoscope"></i>
          </div>
          <i class="fa-solid fa-hospital-user text-5xl mb-4 opacity-90"></i>
          <h2 class="text-2xl font-bold">เข้าสู่ระบบ</h2>
          <p class="text-primary-100 text-xs mt-1">กรุณาใช้อีเมลที่ลงทะเบียนไว้ในระบบ</p>
        </div>
        
        <div class="p-8">
          <form onsubmit="handleLogin(event)" class="space-y-6">
            <div>
              <label for="loginEmail" class="block text-sm font-semibold text-slate-700 mb-2">ที่อยู่อีเมล (Email Address)</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
                  <i class="fa-solid fa-envelope"></i>
                </span>
                <input type="email" id="loginEmail" required placeholder="name@domain.com"
                  class="block w-full pl-10 pr-4 py-3 border border-slate-200 rounded-xl text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all text-sm font-medium">
              </div>
            </div>
            
            <button type="submit" class="w-full py-3.5 px-4 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold rounded-xl transition-all shadow-lg shadow-primary-600/20 text-sm">
              เข้าสู่ระบบ <i class="fa-solid fa-chevron-right ml-1"></i>
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- ================= PAGE 2: RESIDENT PORTAL ================= -->
    <section id="residentPortal" class="fade-in space-y-8 hidden">
      <div class="bg-gradient-to-r from-teal-50 to-emerald-50 border border-teal-100 rounded-2xl p-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h2 class="text-xl font-bold text-teal-900">สวัสดี, <span id="resWelcomeName">-</span></h2>
          <p class="text-xs text-teal-700 font-medium mt-0.5">รหัสแพทย์ประจำบ้าน: <span id="resWelcomeId">-</span> | ปีการศึกษา: ปี <span id="resWelcomeYear">-</span></p>
        </div>
        <div class="flex items-center space-x-3">
          <button onclick="printResidentPortalReport()" class="px-5 py-3 bg-teal-600 hover:bg-teal-700 text-white font-bold rounded-xl shadow-md transition-all text-sm flex items-center space-x-2">
            <i class="fa-solid fa-print"></i>
            <span>พิมพ์รายงาน / PDF</span>
          </button>
          <button onclick="openLeaveModal()" class="px-5 py-3 bg-primary-600 hover:bg-primary-700 active:bg-primary-800 text-white font-bold rounded-xl shadow-md shadow-primary-600/10 transition-all text-sm flex items-center space-x-2">
            <i class="fa-solid fa-paper-plane"></i>
            <span>ยื่นใบลาใหม่</span>
          </button>
        </div>
      </div>

      <!-- Leave Balances Dashboard -->
      <div>
        <h3 class="text-base font-bold text-slate-900 mb-4 flex items-center space-x-2">
          <i class="fa-solid fa-chart-pie text-primary-600"></i>
          <span>สิทธิ์วันลาคงเหลือประจำปี</span>
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -right-4 -bottom-4 opacity-5 text-7xl text-teal-600">
              <i class="fa-solid fa-umbrella-beach"></i>
            </div>
            <div>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-teal-50 text-teal-700 mb-4">
                <i class="fa-solid fa-umbrella-beach mr-1"></i> ลาพักร้อน / พักผ่อน
              </span>
              <div class="flex items-baseline space-x-2">
                <span id="vacationRemaining" class="text-3xl font-extrabold text-slate-900">-</span>
                <span class="text-slate-400 text-sm font-medium">วันคงเหลือ</span>
              </div>
            </div>
            <div class="mt-6">
              <div class="flex justify-between text-xs font-semibold text-slate-500 mb-1.5">
                <span>ใช้ไปแล้ว <span id="vacationUsed">-</span> วัน</span>
                <span>สิทธิ์ทั้งหมด <span id="vacationLimit">-</span> วัน</span>
              </div>
              <div class="w-full bg-slate-100 rounded-full h-2">
                <div id="vacationProgress" class="bg-teal-500 h-2 rounded-full transition-all duration-500" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -right-4 -bottom-4 opacity-5 text-7xl text-rose-600">
              <i class="fa-solid fa-heart-crack"></i>
            </div>
            <div>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-rose-50 text-rose-700 mb-4">
                <i class="fa-solid fa-kit-medical mr-1"></i> ลาป่วย
              </span>
              <div class="flex items-baseline space-x-2">
                <span id="sickUsedCard" class="text-3xl font-extrabold text-slate-900">-</span>
                <span class="text-slate-400 text-sm font-medium">วันใช้ไป</span>
              </div>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-50">
              <p class="text-xs text-slate-500 font-medium flex items-center">
                <i class="fa-solid fa-circle-info mr-1 text-slate-400"></i> ลาป่วยได้ตามจริงที่เป็นโรค
              </p>
            </div>
          </div>

          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute -right-4 -bottom-4 opacity-5 text-7xl text-amber-600">
              <i class="fa-solid fa-briefcase"></i>
            </div>
            <div>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-700 mb-4">
                <i class="fa-solid fa-business-time mr-1"></i> ลากิจ
              </span>
              <div class="flex items-baseline space-x-2">
                <span id="personalUsedCard" class="text-3xl font-extrabold text-slate-900">-</span>
                <span class="text-slate-400 text-sm font-medium">วันใช้ไป</span>
              </div>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-50">
              <p class="text-xs text-slate-500 font-medium flex items-center">
                <i class="fa-solid fa-circle-info mr-1 text-slate-400"></i> ลากิจจำเป็นเมื่อมีธุระส่วนตัว
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- History Table -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <h3 class="text-base font-bold text-slate-900 flex items-center space-x-2">
            <i class="fa-solid fa-clock-rotate-left text-primary-600"></i>
            <span>ประวัติการลาพัก/ลาป่วยของคุณ</span>
          </h3>
          <span id="historyCount" class="inline-flex px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-full">0 รายการ</span>
        </div>
        
        <div class="overflow-x-auto custom-scrollbar">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider border-b border-slate-100">
                <th class="px-6 py-4">รหัสใบลา</th>
                <th class="px-6 py-4">ประเภท</th>
                <th class="px-6 py-4">ระยะเวลา</th>
                <th class="px-6 py-4 text-center">จำนวนวัน</th>
                <th class="px-6 py-4">เหตุผลการลา</th>
                <th class="px-6 py-4">อาจารย์ที่ปรึกษา</th>
                <th class="px-6 py-4">ผู้สลับเวร (ถ้ามี)</th>
                <th class="px-6 py-4 text-center">สถานะ</th>
                <th class="px-6 py-4 text-center">การจัดการ</th>
              </tr>
            </thead>
            <tbody id="residentHistoryBody" class="divide-y divide-slate-100 text-sm font-medium">
            </tbody>
          </table>
        </div>
        
        <div id="noHistoryMsg" class="hidden py-16 text-center text-slate-400 flex flex-col items-center justify-center space-y-3">
          <i class="fa-solid fa-folder-open text-4xl opacity-50"></i>
          <p class="text-sm font-medium">ยังไม่พบประวัติการส่งใบลา</p>
        </div>
      </div>
    </section>

    <!-- ================= PAGE 3: MENTOR PORTAL ================= -->
    <section id="mentorPortal" class="fade-in space-y-8 hidden">
      <div class="bg-gradient-to-r from-primary-800 to-primary-950 text-white rounded-3xl p-8 relative overflow-hidden shadow-lg">
        <div class="absolute -right-8 -bottom-8 opacity-10 text-9xl">
          <i class="fa-solid fa-user-tie"></i>
        </div>
        <span class="inline-flex px-3 py-1 bg-primary-700/50 text-primary-200 text-xs font-bold rounded-full mb-3 backdrop-blur-sm">
          อาจารย์ที่ปรึกษา (Mentor Portal)
        </span>
        <h2 class="text-2xl font-bold text-white">เรียน อาจารย์ <span id="mentorWelcomeName">-</span></h2>
        <p class="text-primary-200 text-xs mt-1">ยินดีต้อนรับสู่ระบบพิจารณาอนุมัติใบลาและประเมินภาพรวมแพทย์ประจำบ้านทั้งหมดในแผนก</p>
      </div>

      <!-- Navigation Tabs for Mentor Portal -->
      <div class="border-b border-slate-200">
        <nav class="flex space-x-6" aria-label="Tabs">
          <button onclick="switchMentorTab('pending')" id="tabBtn-pending" class="border-primary-600 text-primary-600 border-b-2 py-4 px-1 text-sm font-bold flex items-center space-x-2">
            <i class="fa-solid fa-hourglass-half"></i>
            <span>ใบลาค้างอนุมัติถึงท่าน</span>
          </button>
          <button onclick="switchMentorTab('dashboard')" id="tabBtn-dashboard" class="border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 border-b-2 py-4 px-1 text-sm font-bold flex items-center space-x-2">
            <i class="fa-solid fa-chart-line"></i>
            <span>ภาพรวมการลาแพทย์ประจำบ้านทั้งหมด</span>
          </button>
          <button onclick="switchMentorTab('history')" id="tabBtn-history" class="border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300 border-b-2 py-4 px-1 text-sm font-bold flex items-center space-x-2">
            <i class="fa-solid fa-check-double"></i>
            <span>ประวัติการทำรายการโดยท่าน</span>
          </button>
        </nav>
      </div>

      <!-- TAB Content 1: Pending Leaves -->
      <div id="mentorTab-pending" class="space-y-4">
        <h3 class="text-base font-bold text-slate-900 flex items-center space-x-2">
          <i class="fa-solid fa-hourglass-half text-amber-500"></i>
          <span>รายการใบลาที่รออาจารย์อนุมัติ</span>
        </h3>
        
        <div id="pendingRequestsContainer" class="grid grid-cols-1 md:grid-cols-2 gap-6">
        </div>

        <div id="noPendingRequestsMsg" class="hidden bg-white py-16 border border-slate-200 rounded-2xl text-center text-slate-400 flex flex-col items-center justify-center space-y-3 shadow-sm">
          <i class="fa-solid fa-circle-check text-4xl text-teal-500 opacity-80"></i>
          <p class="text-sm font-semibold text-slate-700">ไม่มีใบลาค้างพิจารณาถึงท่านในขณะนี้</p>
          <p class="text-xs text-slate-400">เมื่อมีแพทย์ประจำบ้านยื่นใบลาโดยระบุชื่อท่าน ระบบจะแสดงคำขอลาที่นี่</p>
        </div>
      </div>

      <!-- TAB Content 2: Overall Leave Dashboard -->
      <div id="mentorTab-dashboard" class="space-y-6 hidden">
        <!-- Search and Filter -->
        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="relative flex-grow max-w-md">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-400">
              <i class="fa-solid fa-magnifying-glass"></i>
            </span>
            <input type="text" id="mentorSearchResident" oninput="filterDashboardResidents()" placeholder="ค้นหาตามชื่อ, ชั้นปี หรืออาจารย์ที่ปรึกษา..."
              class="block w-full pl-10 pr-4 py-2.5 border border-slate-200 rounded-xl text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm font-medium">
          </div>
          <div class="flex items-center space-x-2 text-xs font-semibold text-slate-400">
            <i class="fa-solid fa-circle-info"></i>
            <span>อาจารย์ทุกท่านสามารถกดคลิกแถวเพื่อดูรายละเอียดวันลาแยกรายบุคคลได้</span>
          </div>
        </div>

        <!-- Supervised Residents Table -->
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 py-5 border-b border-slate-200 bg-slate-50/50">
            <h3 class="text-base font-bold text-slate-900 flex items-center space-x-2">
              <i class="fa-solid fa-user-md text-primary-600"></i>
              <span>ข้อมูลสถิติวันลาสะสมแพทย์ประจำบ้านทั้งหมด</span>
            </h3>
          </div>
          
          <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider border-b border-slate-100">
                  <th class="px-6 py-4">รหัสแพทย์</th>
                  <th class="px-6 py-4">ชื่อ-นามสกุล</th>
                  <th class="px-6 py-4 text-center">ชั้นปี</th>
                  <th class="px-6 py-4">อาจารย์ที่ปรึกษา</th>
                  <th class="px-6 py-4">ลาพักร้อนคงเหลือ / สิทธิ์</th>
                  <th class="px-6 py-4 text-center">ลาป่วย (วัน)</th>
                  <th class="px-6 py-4 text-center">ลากิจ (วัน)</th>
                  <th class="px-6 py-4 text-center">ค้างพิจารณา</th>
                  <th class="px-6 py-4 text-center">การจัดการ</th>
                </tr>
              </thead>
              <tbody id="mentorDashboardBody" class="divide-y divide-slate-100 text-sm font-medium">
              </tbody>
            </table>
          </div>
          
          <div id="noDashboardResidentsMsg" class="hidden py-16 text-center text-slate-400 flex flex-col items-center justify-center space-y-3">
            <i class="fa-solid fa-users-slash text-4xl opacity-50"></i>
            <p class="text-sm font-medium">ไม่พบรายชื่อแพทย์ประจำบ้านในระบบ</p>
          </div>
        </div>
      </div>

      <!-- TAB Content 3: Action History -->
      <div id="mentorTab-history" class="space-y-4 hidden">
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
          <div class="px-6 py-5 border-b border-slate-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <h3 class="text-base font-bold text-slate-900 flex items-center space-x-2">
              <i class="fa-solid fa-check-double text-slate-500"></i>
              <span>ประวัติการอนุมัติ/ปฏิเสธโดยอาจารย์</span>
            </h3>
            <span id="mentorHistoryCount" class="inline-flex px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-full">0 รายการ</span>
          </div>
          
          <div class="overflow-x-auto custom-scrollbar">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50 text-slate-500 text-xs font-bold uppercase tracking-wider border-b border-slate-100">
                  <th class="px-6 py-4">รหัสใบลา</th>
                  <th class="px-6 py-4">แพทย์ผู้ลา</th>
                  <th class="px-6 py-4">ประเภท</th>
                  <th class="px-6 py-4">ระยะเวลา</th>
                  <th class="px-6 py-4 text-center">จำนวนวัน</th>
