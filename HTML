    function showToast(message, type = 'success') {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      
      toast.className = `p-4 rounded-xl shadow-lg border text-sm font-medium flex items-center space-x-3 pointer-events-auto fade-in transition-all duration-300 transform translate-x-12`;
      
      let icon = '';
      if (type === 'success') {
        toast.className += ' bg-teal-50 border-teal-100 text-teal-800';
        icon = '<i class="fa-solid fa-circle-check text-teal-500 text-base"></i>';
      } else if (type === 'error') {
        toast.className += ' bg-rose-50 border-rose-100 text-rose-800';
        icon = '<i class="fa-solid fa-circle-xmark text-rose-500 text-base"></i>';
      } else {
        toast.className += ' bg-blue-50 border-blue-100 text-blue-800';
        icon = '<i class="fa-solid fa-circle-info text-blue-500 text-base"></i>';
      }
      
      toast.innerHTML = `${icon} <span>${message}</span>`;
      container.appendChild(toast);
      
      setTimeout(() => {
        toast.classList.remove('translate-x-12');
      }, 10);
      
      setTimeout(() => {
        toast.classList.add('opacity-0', 'translate-x-12');
        setTimeout(() => {
          toast.remove();
        }, 300);
      }, 4000);
    }

    function showPage(pageId) {
      ['loginPage', 'residentPortal', 'mentorPortal', 'roleSelectionPage'].forEach(id => {
