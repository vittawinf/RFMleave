    async function handleMentorEditSubmit(e) {
      e.preventDefault();
      
      const requestId = document.getElementById('mentorEditRequestId').value;
      const type = document.getElementById('mentorEditLeaveType').value;
      const department = document.getElementById('mentorEditDepartment').value.trim();
      const startDate = document.getElementById('mentorEditStartDate').value;
      const endDate = document.getElementById('mentorEditEndDate').value;
      const totalDays = Number(document.getElementById('mentorEditTotalDays').textContent);
      const reason = document.getElementById('mentorEditReason').value.trim();
      const substituteId = document.getElementById('mentorEditSubstitute').value;
      const contactAddress = document.getElementById('mentorEditContactAddress').value.trim();
      const phoneNumber = document.getElementById('mentorEditPhoneNumber').value.trim();
      
      const data = {
        type: type,
        department: department,
        startDate: startDate,
        endDate: endDate,
        totalDays: totalDays,
        reason: reason,
        substituteId: substituteId,
        contactAddress: contactAddress,
        phoneNumber: phoneNumber
      };
      
      closeMentorEditModal();
      setGlobalLoading(true, "กำลังบันทึกการแก้ไขและปรับยอดวันลา...");
      
      try {
        const response = await callBackend('mentorEditApprovedRequest', requestId, data, currentUserEmail);
        setGlobalLoading(false);
        if (response.success) {
          showToast(response.message, 'success');
          loadMentorPortal();
          closeDrilldownModal();
