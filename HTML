      currentMentorTab = tabId;
      
      ['pending', 'dashboard', 'history'].forEach(t => {
        const btn = document.getElementById(`tabBtn-${t}`);
        const section = document.getElementById(`mentorTab-${t}`);
        
        if (t === tabId) {
          btn.className = "border-primary-600 text-primary-600 border-b-2 py-4 px-1 text-sm font-bold flex items-center space-x-2";
          section.classList.remove('hidden');
