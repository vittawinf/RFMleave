    function calculateMentorEditDuration() {
      const start = document.getElementById('mentorEditStartDate').value;
      const end = document.getElementById('mentorEditEndDate').value;
      if (!start || !end) return;
      
      const sDate = new Date(start);
      const eDate = new Date(end);
      
      if (eDate < sDate) {
        document.getElementById('mentorEditEndDate').value = start;
        document.getElementById('mentorEditTotalDays').textContent = "1";
        return;
      }
      
      const diffTime = Math.abs(eDate - sDate);
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
      document.getElementById('mentorEditTotalDays').textContent = diffDays;
    }

    function openMentorEditModal(requestId) {
      const req = loadedRequestsMap[requestId];
      if (!req) {
        showToast("ไม่พบข้อมูลใบลาสำหรับการแก้ไข", "error");
        return;
      }
      
      document.getElementById('mentorEditRequestId').value = req.id;
      document.getElementById('mentorEditRequestIdDisplay').textContent = req.id;
      document.getElementById('mentorEditResidentInfo').textContent = `${req.residentName || req.profile?.name || '-'} (รหัส: ${req.residentId || req.profile?.id || '-'})`;
      
      document.getElementById('mentorEditLeaveType').value = req.type;
      document.getElementById('mentorEditDepartment').value = req.department || '';
      document.getElementById('mentorEditReason').value = req.reason || '';
      
      // Populate substitute select
      const subSelect = document.getElementById('mentorEditSubstitute');
      subSelect.innerHTML = '<option value="">-- เลือกผู้สลับเวร (ถ้ามี) --</option>';
      if (loadedMentorResidentsList && loadedMentorResidentsList.length > 0) {
        loadedMentorResidentsList.forEach(r => {
          if (r.id !== req.residentId) {
            subSelect.innerHTML += `<option value="${r.id}">${r.name} (${r.id})</option>`;
          }
        });
      }
      subSelect.value = req.substituteId || '';
      
      document.getElementById('mentorEditContactAddress').value = req.contactAddress || '';
      document.getElementById('mentorEditPhoneNumber').value = req.phoneNumber || '';
      
      if (req.startDate) {
        document.getElementById('mentorEditStartDate').value = new Date(req.startDate).toISOString().split('T')[0];
      }
      if (req.endDate) {
        document.getElementById('mentorEditEndDate').value = new Date(req.endDate).toISOString().split('T')[0];
      }
      
      calculateMentorEditDuration();
      document.getElementById('mentorEditModal').classList.remove('hidden');
    }

