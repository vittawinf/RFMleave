    function openEditModal(requestId) {
      if (!loadedResidentData) return;
      
      const req = loadedResidentData.history.find(h => h.id === requestId);
      if (!req) return;
      
      currentEditingRequestId = requestId;
      document.getElementById('leaveModalTitle').textContent = `แก้ไขใบลาเลขที่ ${requestId}`;
      document.getElementById('formSubmitBtn').textContent = "บันทึกการแก้ไข";
      document.getElementById('formResidentEmail').value = currentUserEmail;
      
      document.getElementById('formLeaveType').value = req.type;
      document.getElementById('formDepartment').value = req.department || '';
      document.getElementById('formReason').value = req.reason || '';
      document.getElementById('formSubstitute').value = req.substituteId || '';
      document.getElementById('formContactAddress').value = req.contactAddress || '';
      document.getElementById('formPhoneNumber').value = req.phoneNumber || '';
      
      const mentorSelect = document.getElementById('formMentor');
      for (let i = 0; i < mentorSelect.options.length; i++) {
        const val = mentorSelect.options[i].value;
        if (val && val.split('|')[0] === req.mentorEmail) {
          mentorSelect.selectedIndex = i;
          break;
        }
      }
      
      if (req.startDate) {
        document.getElementById('formStartDate').value = new Date(req.startDate).toISOString().split('T')[0];
      }
      if (req.endDate) {
        document.getElementById('formEndDate').value = new Date(req.endDate).toISOString().split('T')[0];
      }
      
      calculateDuration();
      document.getElementById('leaveModal').classList.remove('hidden');
    }
    
