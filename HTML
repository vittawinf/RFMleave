    function callBackend(funcName, ...args) {
      return new Promise((resolve, reject) => {
        if (typeof google !== 'undefined' && google.script && google.script.run) {
          google.script.run
            .withSuccessHandler(resolve)
            .withFailureHandler(reject)[funcName](...args);
        } else if (typeof APPS_SCRIPT_WEBAPP_URL !== 'undefined' && APPS_SCRIPT_WEBAPP_URL !== "") {
          // โหมดดึงข้อมูลจากภายนอก (CORS Safe โดยส่งเป็น text/plain ป้องกัน Preflight OPTIONS)
          fetch(APPS_SCRIPT_WEBAPP_URL, {
            method: 'POST',
            headers: {
              'Content-Type': 'text/plain;charset=utf-8'
            },
            body: JSON.stringify({ action: funcName, arguments: args })
          })
          .then(res => {
            if (!res.ok) {
              throw new Error("HTTP error! Status: " + res.status);
            }
            return res.json();
          })
          .then(response => {
            if (response && response.success) {
              resolve(response.data);
            } else {
              reject(response ? response.message : "เกิดข้อผิดพลาดในการดึงข้อมูลจาก API");
            }
          })
          .catch(err => {
            console.error("API Call error:", err);
            reject("เชื่อมต่อเซิร์ฟเวอร์ล้มเหลว: " + err.toString());
          });
        } else {
          console.warn("Running in local mock mode (google.script.run and APPS_SCRIPT_WEBAPP_URL not detected)");
          setTimeout(() => {
            mockBackendResponse(funcName, args, resolve, reject);
          }, 600);
        }
      });
    }

    function setGlobalLoading(show, text = 'กำลังโหลดข้อมูล...') {
      const overlay = document.getElementById('loadingOverlay');
      const textEl = document.getElementById('loadingText');
      if (show) {
        textEl.textContent = text;
        overlay.classList.remove('hidden');
      } else {
        overlay.classList.add('hidden');
      }
    }

    async function handleLogin(e) {
      if (e) e.preventDefault();
      const email = document.getElementById('loginEmail').value.trim();
      if (!email) return;
      
      setGlobalLoading(true, "กำลังตรวจสอบข้อมูลผู้ใช้งาน...");
      
      try {
        const response = await callBackend('checkUserRole', email);
        setGlobalLoading(false);
        
        if (response.success) {
          currentUserEmail = email;
          localStorage.setItem('rfm_leave_email', email);
          document.getElementById('userBadge').classList.remove('hidden');
          
          if (response.role === 'both') {
            currentUserName = response.mentorName || response.residentProfile.name;
            document.getElementById('badgeUserName').textContent = currentUserName;
            document.getElementById('badgeUserRole').textContent = "แพทย์และอาจารย์";
            showPage('roleSelectionPage');
          } else if (response.role === 'mentor') {
            currentUserRole = 'mentor';
            currentUserName = response.mentorName;
            document.getElementById('badgeUserName').textContent = currentUserName;
            document.getElementById('badgeUserRole').textContent = "อาจารย์ที่ปรึกษา";
            loadMentorPortal();
          } else if (response.role === 'resident') {
            currentUserRole = 'resident';
            currentUserName = response.residentProfile.name;
            document.getElementById('badgeUserName').textContent = currentUserName;
            document.getElementById('badgeUserRole').textContent = "แพทย์ประจำบ้าน";
            loadResidentPortal();
          }
        } else {
          showToast(response.message, 'error');
        }
      } catch (err) {
        setGlobalLoading(false);
        showToast("เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์: " + err.toString(), 'error');
      }
    }

