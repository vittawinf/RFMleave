    function formatDateString(isoString) {
      if (!isoString) return '-';
      try {
        const d = new Date(isoString);
        const day = String(d.getDate()).padStart(2, '0');
        const month = String(d.getMonth() + 1).padStart(2, '0');
        const year = d.getFullYear() + 543;
        return `${day}/${month}/${year}`;
      } catch (e) {
        return isoString;
      }
    }

