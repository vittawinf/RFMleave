    function onLeaveTypeChange() {
      calculateDuration();
    }

    function calculateDuration() {
      const start = document.getElementById('formStartDate').value;
      const end = document.getElementById('formEndDate').value;
      if (!start || !end) return;
      
      const sDate = new Date(start);
      const eDate = new Date(end);
      
      if (eDate < sDate) {
        document.getElementById('formEndDate').value = start;
        document.getElementById('formTotalDays').textContent = "1";
        return;
      }
      
      const diffTime = Math.abs(eDate - sDate);
      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
      document.getElementById('formTotalDays').textContent = diffDays;
    }

