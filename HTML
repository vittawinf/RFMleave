    function openRejectModal(requestId) {
      selectedRequestIdForRejection = requestId;
      document.getElementById('rejectReasonText').value = '';
      document.getElementById('rejectModal').classList.remove('hidden');
    }
    
    function closeRejectModal() {
      document.getElementById('rejectModal').classList.add('hidden');
      selectedRequestIdForRejection = null;
    }

    async function submitRejection() {
      const reason = document.getElementById('rejectReasonText').value.trim();
      if (!reason) {
        showToast("กรุณากรอกเหตุผลการปฏิเสธ", "error");
        return;
      }
      
      const reqId = selectedRequestIdForRejection;
      closeRejectModal();
      setGlobalLoading(true, "กำลังปฏิเสธการลา...");
      
      try {
        const response = await callBackend('approveOrRejectLeaveRequest', reqId, 'Rejected', currentUserEmail, reason);
        setGlobalLoading(false);
        if (response.success) {
          showToast(response.message, 'success');
          loadMentorPortal();
        } else {
          showToast(response.message, 'error');
        }
      } catch (err) {
        setGlobalLoading(false);
        showToast("เกิดข้อผิดพลาดในการทำรายการ: " + err.toString(), 'error');
      }
