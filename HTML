      if (!confirm(`ยืนยันการอนุมัติใบลาหมายเลข ${requestId} หรือไม่?`)) return;
      
      setGlobalLoading(true, "กำลังอนุมัติใบลาพร้อมคำนวณวันลาคงเหลือ...");
      
      try {
        const response = await callBackend('approveOrRejectLeaveRequest', requestId, 'Approved', currentUserEmail, '');
        setGlobalLoading(false);
        if (response.success) {
          showToast(response.message, 'success');
          loadMentorPortal();
        } else {
          showToast(response.message, 'error');
        }
      } catch (err) {
        setGlobalLoading(false);
        showToast("เกิดข้อผิดพลาดในการทำรายการ: " + err.toString(), 'error');
      }
