      if (!confirm(confirmMsg)) return;
      
      setGlobalLoading(true, "กำลังดำเนินการยกเลิกคำขอลา...");
      
      try {
        const response = await callBackend('cancelLeaveRequest', requestId, currentUserEmail);
        setGlobalLoading(false);
        
        if (response.success) {
          showToast(response.message, 'success');
          loadResidentPortal();
        } else {
          showToast(response.message, 'error');
        }
      } catch (err) {
        setGlobalLoading(false);
        showToast("เกิดข้อผิดพลาดในการส่งคำขอยกเลิก: " + err.toString(), 'error');
