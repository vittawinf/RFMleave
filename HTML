      const substituteId = document.getElementById('formSubstitute').value;
      const mentorRaw = document.getElementById('formMentor').value;
      const contactAddress = document.getElementById('formContactAddress').value.trim();
      const phoneNumber = document.getElementById('formPhoneNumber').value.trim();
      
      if (!mentorRaw) {
        showToast("กรุณาเลือกอาจารย์ที่ปรึกษา", "error");
        return;
      }
      
      const [mentorEmail, mentorName] = mentorRaw.split('|');
      
      const requestData = {
        residentEmail: email,
        type: type,
        department: department,
        startDate: startDate,
        endDate: endDate,
        totalDays: totalDays,
        reason: reason,
        substituteId: substituteId,
        mentorEmail: mentorEmail,
        mentorName: mentorName,
        contactAddress: contactAddress,
        phoneNumber: phoneNumber
      };
      
      closeLeaveModal();
      
      let backendFunc = 'submitLeaveRequest';
      let loadingMessage = "กำลังยื่นใบลาต่ออาจารย์ที่ปรึกษา...";
      
      if (currentEditingRequestId) {
        backendFunc = 'editLeaveRequest';
        loadingMessage = "กำลังบันทึกการแก้ไขข้อมูลใบลา...";
      }
      
      setGlobalLoading(true, loadingMessage);
      
      try {
        let response;
        if (currentEditingRequestId) {
          response = await callBackend(backendFunc, currentEditingRequestId, requestData, currentUserEmail);
        } else {
          response = await callBackend(backendFunc, requestData);
        }
        
        setGlobalLoading(false);
        if (response.success) {
          showToast(response.message, 'success');
          loadResidentPortal();
        } else {
          showToast(response.message, 'error');
        }
      } catch (err) {
        setGlobalLoading(false);
        showToast("เกิดข้อผิดพลาดในการบันทึกข้อมูล: " + err.toString(), 'error');
      }
    }

    async function cancelRequest(requestId, isApproved) {
      let confirmMsg = `ยืนยันการยกเลิกคำขอใบลาหมายเลข ${requestId} หรือไม่?`;
      if (isApproved) {
